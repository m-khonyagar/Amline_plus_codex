<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Rental Contract</title>
    <style>
      body { font-family: Arial, sans-serif; margin: 32px; }
      h1 { margin: 0 0 16px 0; }
      .row { margin: 8px 0; }
      .label { display: inline-block; width: 180px; color: #444; }
      .value { font-weight: 600; }
      .sig { margin-top: 28px; display: flex; gap: 48px; }
      .sig .box { width: 45%; border-top: 1px solid #999; padding-top: 10px; }
    </style>
  </head>
  <body>
    <h1>Contract</h1>

    <div class="row"><span class="label">Owner:</span> <span class="value">{{owner_name}}</span></div>
    <div class="row"><span class="label">Tenant:</span> <span class="value">{{tenant_name}}</span></div>
    <div class="row"><span class="label">Rent Amount:</span> <span class="value">{{rent_amount}}</span></div>
    <div class="row"><span class="label">Deposit Amount:</span> <span class="value">{{deposit_amount}}</span></div>
    <div class="row"><span class="label">Start Date:</span> <span class="value">{{start_date}}</span></div>
    <div class="row"><span class="label">End Date:</span> <span class="value">{{end_date}}</span></div>
    <div class="row"><span class="label">Tracking Code:</span> <span class="value">{{tracking_code}}</span></div>

    <div class="sig">
      <div class="box">Owner Signature: {{owner_signed}}</div>
      <div class="box">Tenant Signature: {{tenant_signed}}</div>
    </div>
  </body>
</html>
